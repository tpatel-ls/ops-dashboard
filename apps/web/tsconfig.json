{
  "extends": "@drift/tsconfig/nextjs.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", ".next", "dist", "capacitor.config.ts", "src/app/sw.ts"]
}
